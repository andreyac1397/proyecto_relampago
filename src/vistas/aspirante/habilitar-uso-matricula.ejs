<div class="card form-card">

  <p>
    <strong>Solicitar una cita de matrícula</strong>.
  </p>

  <p class="muted">
    Estado actual:
    <strong>
      <%= resumen?.habilitado ? 'Cita solicitada / En cola para asignación' : 'No solicitado' %>
    </strong>
  </p>

  <form method="POST" action="/aspirante/habilitar-uso-matricula">
    <button class="btn" type="submit">
      Solicitar cita de matrícula
    </button>
  </form>

  <!-- 🔴 MENSAJE SI NO HA COMPLETADO DATOS -->
  <% if (!resumen?.datos_completos) { %>
    <p class="muted" style="color:red;">
      Debes completar tus datos personales antes de solicitar la cita.
    </p>
  <% } %>

  <!-- 🟢 MENSAJE SI YA SOLICITÓ -->
  <% if (resumen?.habilitado) { %>

    <p class="muted">
      Ya solicitaste tu cita. Estás en cola para la asignación de fecha y hora según el orden de fila.
    </p>

  <% } %>

</div>