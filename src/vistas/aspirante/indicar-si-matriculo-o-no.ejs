<form class="card form-card" method="POST">
  <label>Estado de matrícula</label>
  <select name="estado" required>
    <option value="Matriculado">Matriculado</option>
    <option value="No matriculado">No matriculado</option>
    <option value="Pendiente">Pendiente</option>
  </select>
  <label>Observación</label>
  <textarea name="observacion" rows="4" placeholder="Opcional"></textarea>
  <button class="btn" type="submit">Actualizar estado</button>
</form>
