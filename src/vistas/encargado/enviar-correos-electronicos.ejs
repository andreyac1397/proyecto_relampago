<form class="card form-card inline-form" method="GET">
  <select name="estado">
    <option value="">Selecciona estado</option>
    <option value="Matriculado" <%= estado==='Matriculado'?'selected':'' %>>Matriculado</option>
    <option value="No matriculado" <%= estado==='No matriculado'?'selected':'' %>>No matriculado</option>
    <option value="Pendiente" <%= estado==='Pendiente'?'selected':'' %>>Pendiente</option>
  </select>
  <button class="btn" type="submit">Cargar destinatarios</button>
</form>
<form class="card form-card" method="POST">
  <label>Destinatarios</label>
  <div class="checkbox-list">
    <% destinatarios.forEach(d => { %>
      <label><input type="checkbox" name="ids_persona" value="<%= d.id_persona %>" /> <%= d.nombre_completo %> - <%= d.email %></label>
    <% }) %>
  </div>
  <label>Asunto</label><input name="asunto" required />
  <label>Mensaje</label><textarea name="mensaje" rows="5" required></textarea>
  <button class="btn" type="submit">Registrar correo</button>
</form>
