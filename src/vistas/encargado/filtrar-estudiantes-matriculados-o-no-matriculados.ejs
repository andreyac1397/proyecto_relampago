<form class="card form-card inline-form" method="GET">
  <select name="estado">
    <option value="Matriculado" <%= estado==='Matriculado'?'selected':'' %>>SI (Matriculado)</option>
    <option value="No matriculado" <%= estado==='No matriculado'?'selected':'' %>>NO (No matriculado)</option>
    <option value="Pendiente" <%= estado==='Pendiente'?'selected':'' %>>Pendiente</option>
  </select>
  <button class="btn" type="submit">Filtrar</button>
</form>
<div class="card table-card">
  <table>
    <thead><tr><th>Nombre</th><th>Email</th><th>Teléfono</th><th>Estado</th><th>Carrera</th></tr></thead>
    <tbody>
      <% resultados.forEach(r => { %>
      <tr><td><%= r.nombre %> <%= r.apellido %></td><td><%= r.email %></td><td><%= r.telefono %></td><td><%= r.estado_matricula %></td><td><%= r.carrera || 'Sin carrera' %></td></tr>
      <% }) %>
    </tbody>
  </table>
</div>
