<div class="login-wrapper">
  <form class="card form-card narrow" action="/auth/login" method="POST">
    <h2>Bienvenido</h2>
    <p class="muted">Ingresa con tu usuario y contraseña de la tabla Usuario.</p>

    <label>Nombre de usuario</label>
    <input type="text" name="nombre_usuario" placeholder="Ejemplo: usuario1" required />

    <label>Contraseña</label>
    <input type="password" name="clave" placeholder="Tu contraseña" required />

    <button class="btn full" type="submit">Ingresar</button>
  </form>
</div>
