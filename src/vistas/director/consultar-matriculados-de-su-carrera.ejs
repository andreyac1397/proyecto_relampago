<form class="card form-card inline-form" method="GET">
  <select name="id_carrera">
    <% carreras.forEach(c => { %>
      <option value="<%= c.id_carrera %>" <%= String(idCarrera)===String(c.id_carrera)?'selected':'' %>><%= c.nombre %></option>
    <% }) %>
  </select>
  <button class="btn" type="submit">Consultar</button>
</form>
<div class="card table-card">
  <table>
    <thead><tr><th>Nombre</th><th>Email</th><th>Teléfono</th><th>Estado</th><th>Fecha matrícula</th></tr></thead>
    <tbody>
      <% resultados.forEach(r => { %>
      <tr><td><%= r.nombre %> <%= r.apellido %></td><td><%= r.email %></td><td><%= r.telefono %></td><td><%= r.estado %></td><td><%= r.fecha_matricula ? r.fecha_matricula.toISOString().slice(0,10) : 'N/A' %></td></tr>
      <% }) %>
    </tbody>
  </table>
</div>
